# ─── HH.ru (Russia) ────────────────────────────────────────────────────────────
# Get free credentials: https://dev.hh.ru → Create Application
# App token (no OAuth required for public search)
HH_APP_TOKEN=your_hh_app_token_here
# IMPORTANT: HH.ru blocks generic user agents. Use real contact email.
HH_USER_AGENT=VacancyScanner/1.0 (your@email.com)

# ─── Adzuna (Global: US, EU, AU, CA) ──────────────────────────────────────────
# Free signup <1 min, no credit card: https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ─── JSearch via RapidAPI (LinkedIn + Indeed + Google Jobs aggregator) ─────────
# Free tier, no credit card: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key

# ─── No keys needed ────────────────────────────────────────────────────────────
# Himalayas, RemoteOK, Arbeitnow, Jobicy, Habr Career RSS,
# TrudVsem.ru, WeWorkRemotely, Djinni.co — work out of the box
